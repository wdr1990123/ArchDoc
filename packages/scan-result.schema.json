{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://archdoc.local/schemas/scan-result/v1",
  "title": "ArchDoc Scan Result",
  "type": "object",
  "required": ["schema_version", "repository_id", "solution_path", "scanned_at", "modules", "dependencies", "metrics", "issues"],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0" },
    "repository_id": { "type": "string", "format": "uuid" },
    "solution_path": { "type": "string" },
    "scanned_at": { "type": "string", "format": "date-time" },
    "commit_sha": { "type": "string" },
    "modules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "kind"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "kind": { "type": "string", "enum": ["project", "namespace"] },
          "loc": { "type": "integer", "minimum": 0 },
          "layer": { "type": "string" }
        }
      }
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["from", "to", "kind"],
        "properties": {
          "from": { "type": "string" },
          "to": { "type": "string" },
          "kind": { "type": "string" },
          "weight": { "type": "integer", "minimum": 1 }
        }
      }
    },
    "package_refs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["module_id", "package_id"],
        "properties": {
          "module_id": { "type": "string" },
          "package_id": { "type": "string" },
          "version": { "type": "string" }
        }
      }
    },
    "metrics": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["module_id", "code", "value"],
        "properties": {
          "module_id": { "type": "string" },
          "code": { "type": "string" },
          "value": { "type": "number" }
        }
      }
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["rule_id", "severity", "message"],
        "properties": {
          "rule_id": { "type": "string" },
          "severity": { "type": "string", "enum": ["critical", "high", "medium", "low"] },
          "module_ids": { "type": "array", "items": { "type": "string" } },
          "message": { "type": "string" },
          "location": { "type": "object" }
        }
      }
    },
    "summaries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["module_id"],
        "properties": {
          "module_id": { "type": "string" },
          "top_types": { "type": "array", "items": { "type": "string" } },
          "snippet": { "type": "string" }
        }
      }
    }
  }
}
