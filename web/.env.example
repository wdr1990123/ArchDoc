DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/postgres?options=-c%20search_path%3D%22ArchDoc%22
ARCHDOC_PG_SCHEMA=ArchDoc
ARCHDOC_API_KEY=dev-secret-key

# =============================================================================
# 阶段一：当前公网测试（在「系统设置 → 大模型配置」中维护，推荐）
# 或在此填写作为兜底（未在 UI 配置任何模型时生效）
# =============================================================================
LLM_PROVIDER=openai
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-your-key-here
LLM_MODEL=gpt-4o
LLM_MAX_TOKENS=4096

# 公网测试推荐（任选其一，在 UI 中配置即可）：
#   OpenAI    https://api.openai.com/v1              gpt-4o
#   DeepSeek  https://api.deepseek.com/v1             deepseek-chat
#   通义      https://dashscope.aliyuncs.com/compatible-mode/v1  qwen-plus

# =============================================================================
# 阶段二：未来全内网生产（上线前在 UI 中替换为内网地址，无需改代码）
# =============================================================================
# LLM_BASE_URL=http://qwen.internal/v1
# LLM_API_KEY=<内网 API Key>
# LLM_MODEL=qwen2.5-72b-instruct

JOB_WORKER_ENABLED=true
JOB_POLL_INTERVAL_MS=3000
# 诊断 API 默认异步入队（立即返回 job_id）；设为 true 时 POST /diagnose 同步等待 LLM（仅测试/调试）
# DIAGNOSE_INLINE=true
# 单次 LLM 请求超时（毫秒），模块深度解读可能较慢
# LLM_REQUEST_TIMEOUT_MS=600000
# AI 诊断调试日志（默认开启，写入仓库根 logs/diagnose/；测试可设为 false）
# DIAGNOSE_LOG_ENABLED=true

# Scanner CLI 绝对路径（UI 复制扫描命令时的 cd 目标，修改后需重启 npm run dev）
# NEXT_PUBLIC_SCANNER_DIR=D:/VibeCoding/Code/ArchDoc/scanner

# =============================================================================
# API 自动化测试（可选，推荐配置独立 schema，避免与开发数据混用）
# =============================================================================
# DATABASE_URL_TEST=postgresql://postgres:YOUR_PASSWORD@localhost:5432/postgres?options=-c%20search_path%3D%22ArchDoc_test%22
# ARCHDOC_PG_SCHEMA_TEST=ArchDoc_test
# 首次使用独立测试库：npm run db:init:test
# 未配置 DATABASE_URL_TEST 时，测试会备份/恢复 app_settings 中的 llm_profiles，不影响扫描数据
